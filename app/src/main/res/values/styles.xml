<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#7B5FFF</item>
        <item name="colorPrimaryDark">#0A0A0F</item>
        <item name="colorAccent">#FF5F9E</item>
        <item name="android:windowBackground">#0A0A0F</item>
        <item name="android:statusBarColor">#0A0A0F</item>
        <item name="android:navigationBarColor">#0A0A0F</item>
    </style>

    <style name="AppTheme.TranslucentDialog" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="colorPrimary">#7B5FFF</item>
        <item name="colorAccent">#FF5F9E</item>
    </style>
</resources>
